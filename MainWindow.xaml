<Window x:Class="Assignment2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot - Cybersecurity Awareness Chatbot"
        Height="620" Width="850"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">

    <!-- ============================================================
         MAIN GRID - holds all the different "pages" of the app
         Only one page is visible at a time
         ============================================================ -->
    <Grid>

        <!-- ============================================================
             PAGE 1: HOME PAGE
             The first thing the user sees when they open the app
             Shows ASCII art, a welcome message, and a Start button
             ============================================================ -->
        <Grid x:Name="home_grid" Visibility="Visible">

            <!-- Dark blue gradient background -->
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1A1A2E" Offset="0"/>
                    <GradientStop Color="#16213E" Offset="0.5"/>
                    <GradientStop Color="#0F3460" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Main content stack panel - centered on screen -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="600">

                <!-- ASCII ART - the cybersecurity bot art -->
                <TextBlock
                    FontFamily="Courier New"
                    FontSize="11"
                    Foreground="#00D4FF"
                    TextAlignment="Center"
                    Margin="0,0,0,10"
                    LineHeight="16">
                    <Run Text="  ██████╗ ██╗   ██╗██████╗ ███████╗██████╗ ██████╗  ██████╗ ████████╗ "/>
                    <LineBreak/>
                    <Run Text=" ██╔════╝ ╚██╗ ██╔╝██╔══██╗██╔════╝██╔══██╗██╔══██╗██╔═══██╗╚══██╔══╝ "/>
                    <LineBreak/>
                    <Run Text=" ██║       ╚████╔╝ ██████╔╝█████╗  ██████╔╝██████╔╝██║   ██║   ██║    "/>
                    <LineBreak/>
                    <Run Text=" ██║        ╚██╔╝  ██╔══██╗██╔══╝  ██╔══██╗██╔══██╗██║   ██║   ██║    "/>
                    <LineBreak/>
                    <Run Text=" ╚██████╗    ██║   ██████╔╝███████╗██║  ██║██████╔╝╚██████╔╝   ██║    "/>
                    <LineBreak/>
                    <Run Text="  ╚═════╝    ╚═╝   ╚═════╝ ╚══════╝╚═╝  ╚═╝╚═════╝  ╚═════╝   ╚═╝    "/>
                </TextBlock>

                <!-- Bot icon in ASCII art -->
                <Image Source="/myLogo.jpg"
                       Width="350" Height="200"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                    
                    >


                </Image>

                <!-- Welcome text -->
                <TextBlock
                    Text="Welcome to CyberBot!"
                    FontSize="28"
                    FontWeight="Bold"
                    Foreground="White"
                    TextAlignment="Center"
                    Margin="0,15,0,5"/>

                <!-- Subtitle text -->
                <TextBlock
                    Text="Your AI-powered Cybersecurity Awareness Assistant"
                    FontSize="14"
                    Foreground="#A0A0C0"
                    TextAlignment="Center"
                    Margin="0,0,0,5"/>

                <!-- Tagline -->
                <TextBlock
                    Text="Ask me about passwords, phishing, scams, privacy and more!"
                    FontSize="12"
                    Foreground="#00D4FF"
                    TextAlignment="Center"
                    Margin="0,0,0,30"/>

                <!-- START BUTTON -->
                <Button
                    x:Name="StartButton"
                    Content="🚀 Get Started"
                    Width="200"
                    Height="50"
                    FontSize="16"
                    FontWeight="Bold"
                    Click="StartButton_Click"
                    Cursor="Hand"
                    HorizontalAlignment="Center">

                    <!-- Button styling -->
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#E94560"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="25"
                                            Padding="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#C73652"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>

        </Grid>
        <!-- End of Home Grid -->


        <!-- ============================================================
             PAGE 2: USERNAME PAGE
             Asks the user to enter their name before chatting
             ============================================================ -->
        <Grid x:Name="username_grid" Visibility="Hidden">

            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1A1A2E" Offset="0"/>
                    <GradientStop Color="#16213E" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">


                <!-- Heading -->
                <TextBlock
                    Text="Who Am I Talking To?"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="White"
                    TextAlignment="Center"
                    Margin="0,0,0,10"/>

                <!-- Instructions -->
                <TextBlock
                    Text="Please enter your name to get started."
                    FontSize="13"
                    Foreground="#A0A0C0"
                    TextAlignment="Center"
                    Margin="0,0,0,25"/>

                <!-- Name input box -->
                <TextBox
                    x:Name="UsernameInput"
                    Height="45"
                    FontSize="16"
                    Padding="12,10"
                    Background="#0F3460"
                    Foreground="White"
                    CaretBrush="White"
                    BorderBrush="#00D4FF"
                    BorderThickness="2"
                    Margin="0,0,0,8"
                    KeyDown="UsernameInput_KeyDown"/>

                <!-- Hint text below the input -->
                <TextBlock
                    x:Name="UsernameErrorText"
                    Text=""
                    FontSize="12"
                    Foreground="#E94560"
                    TextAlignment="Center"
                    Margin="0,0,0,20"/>

                <!-- SUBMIT BUTTON -->
                <Button
                    x:Name="SubmitNameButton"
                    Content="✅ Enter Chat"
                    Width="200"
                    Height="45"
                    FontSize="15"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"
                    Click="SubmitNameButton_Click"
                    Cursor="Hand">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#00D4FF"/>
                            <Setter Property="Foreground" Value="#1A1A2E"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="22"
                                            Padding="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#00A8CC"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

            </StackPanel>

        </Grid>
        <!-- End of Username Grid -->


        <!-- ============================================================
             PAGE 3: CHAT PAGE
             The main chatting interface
             ============================================================ -->
        <Grid x:Name="ChatGrid" Visibility="Hidden">

            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#1A1A2E" Offset="0"/>
                    <GradientStop Color="#16213E" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <!-- Row definitions - split the grid into areas -->
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <!-- Top bar / header -->
                <RowDefinition Height="*"/>
                <!-- Chat messages area (takes remaining space) -->
                <RowDefinition Height="80"/>
                <!-- Input area at the bottom -->
            </Grid.RowDefinitions>

            <!-- ============================================================
                 TOP BAR - shows the bot name and user info
                 ============================================================ -->
            <Border Grid.Row="0" Background="#0F3460" Padding="15,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Bot title on the left -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">

                        <!-- Bot icon -->
                        <TextBlock
                            Text="🤖"
                            FontSize="24"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"/>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock
                                Text="CyberBot"
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="White"/>
                            <TextBlock
                                Text="Cybersecurity Awareness Assistant"
                                FontSize="11"
                                Foreground="#00D4FF"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- User name on the right -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right" Orientation="Horizontal">
                        <TextBlock
                            Text="👤 "
                            FontSize="14"
                            Foreground="#A0A0C0"
                            VerticalAlignment="Center"/>
                        <TextBlock
                            x:Name="HeaderUsernameText"
                            Text=""
                            FontSize="14"
                            Foreground="#00D4FF"
                            FontWeight="Bold"
                            VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================================================
                 CHAT MESSAGES AREA
                 Shows all the conversation messages
                 ============================================================ -->
            <ScrollViewer
                Grid.Row="1"
                x:Name="ChatScrollViewer"
                VerticalScrollBarVisibility="Auto"
                Padding="10">

                <!-- ListBox holds all the chat bubbles -->
                <ListBox
                    x:Name="ChatListBox"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="5"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                    <!-- Remove the default selection highlight -->
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0,3"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </ScrollViewer>

            <!-- ============================================================
                 INPUT AREA - where the user types their message
                 ============================================================ -->
            <Border Grid.Row="2" Background="#0F3460" Padding="15,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <!-- Text input takes most space -->
                        <ColumnDefinition Width="100"/>
                        <!-- Send button -->
                    </Grid.ColumnDefinitions>

                    <!-- Message input box -->
                    <TextBox
                        Grid.Column="0"
                        x:Name="MessageInput"
                        Height="45"
                        FontSize="14"
                        Padding="12,10"
                        Background="#1A1A2E"
                        Foreground="White"
                        CaretBrush="White"
                        BorderBrush="#00D4FF"
                        BorderThickness="2"
                        Margin="0,0,10,0"
                        VerticalContentAlignment="Center"
                        KeyDown="MessageInput_KeyDown"/>

                    <!-- SEND BUTTON -->
                    <Button
                        Grid.Column="1"
                        x:Name="SendButton"
                        Content="Send ➤"
                        Height="45"
                        FontSize="14"
                        FontWeight="Bold"
                        Click="SendButton_Click"
                        Cursor="Hand">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#E94560"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="5">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#C73652"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                </Grid>
            </Border>

        </Grid>
        <!-- End of Chat Grid -->

    </Grid>
</Window>